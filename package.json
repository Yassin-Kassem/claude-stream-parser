{
  "name": "claude-stream-parser",
  "version": "0.1.0",
  "description": "A tiny, zero-dependency TypeScript library for parsing Claude's streaming SSE responses into fully typed events.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck"
  },
  "keywords": [
    "anthropic",
    "claude",
    "streaming",
    "sse",
    "server-sent-events",
    "parser",
    "typescript",
    "llm",
    "ai"
  ],
  "author": "Yassin-Kassem",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yassin-Kassem/claude-stream-parser"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0",
    "@types/node": "^20.0.0"
  }
}
